{
  "compilerOptions": { 
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler", 
    "jsx": "react-jsx", 
    "strict": true,
    "noUnusedLocals": true,   
    "noUnusedParameters": true,
    "noImplicitReturns": true,   
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,   
    // "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] }   
  },
  "include": ["src"]
}